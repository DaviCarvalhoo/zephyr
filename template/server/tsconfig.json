{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "types": ["node"],
        "outDir": "./build",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "paths": {
            "#root/*": ["./*"],
            "#api/*": ["./apps/api/*"],
            "#shared/*": ["./apps/shared/*"],
            "#core/*": ["./core/*"]
        }
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "build"]
}
