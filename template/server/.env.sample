# Server — Admin API
PORT={{API_PORT}}
NODE_ENV=development

# Server — Site API (optional second API)
SITE_API_PORT={{SITE_API_PORT}}

# URLs
DOMAIN=http://localhost:{{ADMIN_UI_PORT}}
SITE_DOMAIN=http://localhost:{{SITE_PORT}}
BASE_UI_URL=http://localhost:{{ADMIN_UI_PORT}}
BASE_API_URL=http://localhost:{{API_PORT}}
BASE_SITE_API_URL=http://localhost:{{SITE_API_PORT}}

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME={{DB_NAME}}
DB_USER=postgres
DB_PASSWORD=postgres

# Authentication
JWT_TOKEN_SECRET={{JWT_TOKEN_SECRET}}
COOKIE_DOMAIN=

# Mobile auth — fill these to enable native sign-in
# Apple bundle id (iOS app): used as the audience when verifying Apple
# id_tokens posted from `expo-apple-authentication`.
APPLE_BUNDLE_ID={{IOS_BUNDLE_ID}}

# Google OAuth — server-side flow.
# Web client ID + secret are created in Google Cloud → Credentials.
# Add `${BASE_API_URL}/api/auth/google/callback` as an authorized
# redirect URI.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:{{API_PORT}}/api/auth/google/callback

# Mobile deep-link scheme — must match `scheme` in mobile/<slug>/app.json.
# Used to redirect back to the app after the Google OAuth dance.
MOBILE_SCHEME={{MOBILE_SCHEME}}

# Content API HMAC secret — must match the value in
# mobile/<slug>/src/services/content/sync.ts (CONTENT_SECRET).
# Each request signs HMAC-SHA256(secret, "${timestamp}:${contentPath}")
# so no two requests share the same signature. Rotate by changing
# the secret in both places — there's intentionally no migration path,
# the secret is shared symmetric-key with no per-user state.
CONTENT_SECRET={{CONTENT_SECRET}}

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@{{DOMAIN}}
EMAIL_NAME={{PROJECT_NAME}}
EMAIL_REPLY_TO=suporte@{{DOMAIN}}

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET={{PROJECT_SLUG}}-files
