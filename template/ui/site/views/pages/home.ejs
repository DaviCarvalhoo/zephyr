<%- include('../partials/header') %>

<main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white">
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-0 left-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
            <div class="absolute bottom-0 right-0 w-96 h-96 bg-violet-500 rounded-full filter blur-3xl translate-x-1/2 translate-y-1/2"></div>
        </div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
            <div class="max-w-3xl mx-auto text-center">
                <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
                    <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                    <span class="text-sm font-medium text-white/90"><%= t('hero.badge') %></span>
                </div>

                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
                    <%= t('hero.titleEyebrow') %>
                </h1>

                <p class="text-xl text-white/70 mb-10 max-w-2xl mx-auto">
                    <%= t('hero.subtitle') %>
                </p>

                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
                    <a href="<%= baseAdminUrl %>/signup"
                       class="inline-flex items-center justify-center gap-2 bg-white text-gray-900 px-8 py-3.5 rounded-xl hover:bg-gray-100 transition-all font-semibold text-sm shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                        <%= t('hero.ctaPrimary') %>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                        </svg>
                    </a>
                    <a href="#features"
                       class="inline-flex items-center justify-center gap-2 border border-white/30 text-white px-8 py-3.5 rounded-xl hover:bg-white/10 transition-all font-medium text-sm backdrop-blur-sm">
                        <%= t('hero.ctaSecondary') %>
                    </a>
                </div>

                <div class="flex flex-wrap gap-8 justify-center text-sm text-white/60">
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                        <span><%= t('hero.trust.secure') %></span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                        </svg>
                        <span><%= t('hero.trust.cloud') %></span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        <span><%= t('hero.trust.fast') %></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="absolute bottom-0 left-0 right-0">
            <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
            </svg>
        </div>
    </section>

    <%# Feature accent classes — kept here so we don't translate %>
    <%# Tailwind class names. Order matches features.items array. %>
    <% const featureAccents = [
        { bg: 'bg-blue-50',    bgHover: 'group-hover:bg-blue-100',    fg: 'text-blue-600',
          path: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
        { bg: 'bg-emerald-50', bgHover: 'group-hover:bg-emerald-100', fg: 'text-emerald-600',
          path: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
        { bg: 'bg-violet-50',  bgHover: 'group-hover:bg-violet-100',  fg: 'text-violet-600',
          path: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
        { bg: 'bg-amber-50',   bgHover: 'group-hover:bg-amber-100',   fg: 'text-amber-600',
          path: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12' },
        { bg: 'bg-rose-50',    bgHover: 'group-hover:bg-rose-100',    fg: 'text-rose-600',
          path: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
        { bg: 'bg-cyan-50',    bgHover: 'group-hover:bg-cyan-100',    fg: 'text-cyan-600',
          path: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' }
    ]; %>

    <!-- Features -->
    <section id="features" class="py-20 lg:py-28 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <span class="inline-block bg-gray-100 text-gray-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
                    <%= t('features.eyebrow') %>
                </span>
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    <%= t('features.title') %>
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    <%= t('features.sub') %>
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% (t('features.items', { returnObjects: true }) || []).forEach(function(item, i) {
                       const a = featureAccents[i] || featureAccents[0]; %>
                <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg transition-all group">
                    <div class="w-14 h-14 <%= a.bg %> <%= a.bgHover %> rounded-xl flex items-center justify-center mb-6 transition-colors">
                        <svg class="w-7 h-7 <%= a.fg %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= a.path %>"/>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3"><%= item.title %></h3>
                    <p class="text-gray-600">
                        <%= item.body %>
                    </p>
                </div>
                <% }); %>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="py-20 lg:py-28 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <span class="inline-block bg-gray-200 text-gray-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
                    <%= t('howItWorks.eyebrow') %>
                </span>
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    <%= t('howItWorks.title') %>
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    <%= t('howItWorks.sub') %>
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
                <% (t('howItWorks.steps', { returnObjects: true }) || []).forEach(function(step, i) { %>
                <div class="text-center">
                    <div class="w-16 h-16 bg-gray-900 text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl font-bold">
                        <%= i + 1 %>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2"><%= step.title %></h3>
                    <p class="text-gray-600 text-sm">
                        <%= step.body %>
                    </p>
                </div>
                <% }); %>
            </div>
        </div>
    </section>

    <!-- Trust -->
    <section class="py-16 bg-white border-y border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-wrap justify-center gap-8 md:gap-16">
                <div class="flex items-center gap-3 text-gray-600">
                    <div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900"><%= t('trust.ssl.title') %></p>
                        <p class="text-sm text-gray-400"><%= t('trust.ssl.sub') %></p>
                    </div>
                </div>
                <div class="flex items-center gap-3 text-gray-600">
                    <div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900"><%= t('trust.lgpd.title') %></p>
                        <p class="text-sm text-gray-400"><%= t('trust.lgpd.sub') %></p>
                    </div>
                </div>
                <div class="flex items-center gap-3 text-gray-600">
                    <div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900"><%= t('trust.cloud.title') %></p>
                        <p class="text-sm text-gray-400"><%= t('trust.cloud.sub') %></p>
                    </div>
                </div>
                <div class="flex items-center gap-3 text-gray-600">
                    <div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900"><%= t('trust.backup.title') %></p>
                        <p class="text-sm text-gray-400"><%= t('trust.backup.sub') %></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section id="contact" class="py-20 lg:py-28 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-0 right-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl translate-x-1/2 -translate-y-1/2"></div>
            <div class="absolute bottom-0 left-0 w-96 h-96 bg-violet-500 rounded-full filter blur-3xl -translate-x-1/2 translate-y-1/2"></div>
        </div>

        <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6">
                <%= t('cta.title') %>
            </h2>
            <p class="text-xl text-white/70 mb-10 max-w-2xl mx-auto">
                <%= t('cta.body') %>
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="<%= baseAdminUrl %>/signup"
                   class="inline-flex items-center justify-center gap-2 bg-white text-gray-900 px-8 py-3.5 rounded-xl hover:bg-gray-100 transition-all font-semibold text-sm shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                    <%= t('cta.primary') %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                    </svg>
                </a>
                <a href="mailto:contato@{{DOMAIN}}"
                   class="inline-flex items-center justify-center gap-2 border border-white/30 text-white px-8 py-3.5 rounded-xl hover:bg-white/10 transition-all font-medium text-sm backdrop-blur-sm">
                    <%= t('cta.secondary') %>
                </a>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>

<script>
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
</script>
