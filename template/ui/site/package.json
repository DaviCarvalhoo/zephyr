{
    "name": "{{PROJECT_SLUG}}-site",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "start": "tsx watch app.ts",
        "build:css": "npx tailwindcss -i ./styles/input.css -o ./public/css/output.css --watch",
        "build:css:once": "npx tailwindcss -i ./styles/input.css -o ./public/css/output.css --minify",
        "dev": "concurrently \"npm:build:css\" \"npm:start\"",
        "build": "tsc && npm run build:css:once",
        "lint": "eslint \"**/*.{ts,tsx}\"",
        "lint:fix": "eslint \"**/*.{ts,tsx}\" --fix"
    },
    "dependencies": {
        "cookie-parser": "^1.4.7",
        "dotenv": "^16.4.7",
        "ejs": "^3.1.10",
        "express": "^4.21.2",
        "i18next": "^23.16.5",
        "nodemailer": "^7.0.13"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.7.1",
        "@types/cookie-parser": "^1.4.7",
        "@types/express": "^5.0.0",
        "@types/node": "^22.10.0",
        "concurrently": "^9.2.1",
        "tailwindcss": "^3.4.0",
        "eslint": "^9.39.2",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.53.1"
    }
}
