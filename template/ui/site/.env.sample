PORT={{SITE_PORT}}
NODE_ENV=development
BASE_ADMIN_URL=http://localhost:{{ADMIN_UI_PORT}}

# Canonical absolute URL — used in canonical tags, hreflang
# alternates, sitemap.xml, and robots.txt. Override per environment
# so Google sees the right host (e.g. https://{{DOMAIN}} in prod).
SITE_URL=http://localhost:{{SITE_PORT}}
